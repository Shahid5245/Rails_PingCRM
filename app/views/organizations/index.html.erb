<h1> Organizations </h1>

<% button_to %>

<table class="table table-hover">
  <thead>
    <tr>
      <th scope="col">SI.No</th>
      <th scope="col">Name</th>
      <th scope="col">City</th>
      <th scope="col">Phone</th>
    </tr>
  </thead>
  <tbody>
    <% @organizations.each_with_index do |each_org, index| %>
      <tr class="table-light" >
        <th scope="row"> <%= index+1 %></th>
        <td> <%= each_org.name %></td>
        <td> <%= each_org.city %></td>
        <td> <%= each_org.phone %></td>
      </tr>
    <% end %>
  </tbody>
</table>