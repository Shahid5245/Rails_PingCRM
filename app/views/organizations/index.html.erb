<h1> Organizations </h1>

<br>
<div class="d-flex justify-content-between align-items-center">
  <%= form_tag "/organizations", method: "GET", class: "d-flex" do %>
    <%= text_field_tag :name, params[:name], class: "form-control me-2", placeholder: "Search...", style: "max-width: 250px;" %>
    <%= submit_tag "Search", class: "btn btn-outline-success" %>
  <% end %>

  <%= link_to "Create Organization", new_organization_path, class: "btn btn-primary" %>
</div>
<br>


<table class="table table-hover border">
  <thead class="table-info">
    <tr>
      <th scope="col">SI.No</th>
      <th scope="col">Name</th>
      <th scope="col">City</th>
      <th scope="col">Phone</th>
      <th scope="col"></th>
    </tr>
  </thead>
  <tbody >
    <% @organizations.each_with_index do |each_org, index| %>
      <tr class="table-light">
        <th scope="row"> <%= index + 1 %></th>
        <td> <%= each_org.name.titlecase %> </td>
        <td> <%= each_org.city %> </td>
        <td> <%= each_org.phone %> </td>
        <td>
          <%= link_to "Show", each_org, class: "btn btn-secondary" %>
          <%= link_to "Edit", edit_organization_path(each_org), class: "btn btn-secondary" %> 
        </td>   
      </tr>
    <% end %>
  </tbody>
</table>