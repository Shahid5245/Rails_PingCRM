
<h1> Contacts </h1>

<br>
<div class="d-flex justify-content-between align-items-center">
  <%= form_tag "/contacts", method: "GET", class: "d-flex" do %>
    <%= text_field_tag :name, params[:name], class: "form-control me-2", placeholder: "Search...", style: "max-width: 250px;" %>
    <%= submit_tag "Search", class: "btn btn-outline-success" %>
  <% end %>

  <%= link_to "Create Contact", new_contact_path, class: "btn-indigo" %>
</div>
<br>


<table class="table table-hover border">
  <thead class="table-info">
    <tr>
      <th scope="col">SI.No</th>
      <th scope="col">Name</th>
      <th scope="col">Organization</th>
      <th scope="col">City</th>
      <th scope="col">Phone</th>
      <th scope="col"></th>
    </tr>
  </thead>
  <tbody>
    <% @contacts.each_with_index do |each_contact, index| %>
    <tr onclick="Turbo.visit('<%= contact_path(each_contact) %>')" style="cursor: pointer" class="table-light">
        <th scope="row"> <%= index+1 %></th>
        <td> <%= each_contact.first_name.titlecase %> <%= each_contact.last_name %></td>
        <td> <%= each_contact&.organization&.name %></td>
        <td> <%= each_contact.city %></td>
        <td> <%= each_contact.phone %></td>
        <td> 
          <%= link_to "Show", each_contact, class: "btn btn-secondary" %>
          <%= link_to "edit", edit_contact_path(each_contact), class: "btn btn-secondary" %> 
        </td>   
      </tr>
    <% end %>
  </tbody>
</table>