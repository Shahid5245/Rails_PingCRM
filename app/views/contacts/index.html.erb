<h1> Contacts </h1>

<br>
<%= link_to "Create", new_contact_path, class: "btn btn-primary" %>
<br><br>

<table class="table table-hover border">
  <thead class="table-info">
    <tr>
      <th scope="col">SI.No</th>
      <th scope="col">Name</th>
      <th scope="col">Organization</th>
      <th scope="col">City</th>
      <th scope="col">Phone</th>
      <th scope="col"></th>
    </tr>
  </thead>
  <tbody>
    <% @contacts.each_with_index do |each_contact, index| %>
      <tr class="table-light" >
        <th scope="row"> <%= index+1 %></th>
        <td> <%= each_contact.first_name.titlecase %> <%= each_contact.last_name %></td>
        <td> <%= each_contact&.organization&.name %></td>
        <td> <%= each_contact.city %></td>
        <td> <%= each_contact.phone %></td>
        <td> 
          <%= link_to "Show", each_contact, class: "btn btn-secondary" %>
          <%= link_to "edit", edit_contact_path(each_contact), class: "btn btn-secondary" %> 
        </td>   
      </tr>
    <% end %>
  </tbody>
</table>